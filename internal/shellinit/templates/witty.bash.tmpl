# shellcheck shell=bash
# Witty Bash integration [[ .Version ]]
# Source with: eval "$(witty init bash)"

if [ "${__WITTY_SHELL_INIT_LOADED:-}" != "1" ]; then
  __WITTY_SHELL_INIT_LOADED=1
  __WITTY_BINARY="[[ .BinaryPath ]]"
  __WITTY_DEFAULT_ENABLE="[[ .ShellEnabled ]]"
  __WITTY_DEFAULT_DEBUG="[[ .ShellDebug ]]"

  __witty_debug() {
    local debug="${WITTY_SHELL_DEBUG:-}"
    if [ -z "$debug" ]; then
      debug="$__WITTY_DEFAULT_DEBUG"
    fi
    case "$debug" in
    1 | true | TRUE | True | yes | YES | Yes | on | ON | On)
      printf 'witty shell: %s\n' "$*" >&2
      ;;
    esac
  }

  __witty_should_enable() {
    local enabled="${WITTY_SHELL_ENABLE:-}"
    if [ -z "$enabled" ]; then
      enabled="$__WITTY_DEFAULT_ENABLE"
    fi
    case "$enabled" in
    0 | false | FALSE | False | no | NO | No | off | OFF | Off)
      return 1
      ;;
    esac
    [ -n "${BASH_VERSION:-}" ] || return 1
    case "${BASH_VERSINFO[0]:-0}" in
    [0-3]) return 1 ;;
    esac
    case $- in
    *i*) ;;
    *) return 1 ;;
    esac
    [ -t 0 ] && [ -t 1 ] || return 1
    return 0
  }

  __witty_is_shell_keyword() {
    case "$1" in
    if | then | else | elif | fi | for | while | until | do | done | "case" | "esac" | function | time | coproc | select | in)
      return 0
      ;;
    esac
    return 1
  }

  __witty_is_shell_command() {
    case "$1" in
    command | builtin | alias | unalias | type | hash | help | cd | pwd | exit | logout | history | jobs | fg | bg | disown | export | unset | readonly | local | declare | printf | echo | test | source | . | exec | eval | trap | set | shopt | umask | ulimit | dirs | pushd | popd | ls | cat | grep | egrep | fgrep | awk | sed | find | xargs | sort | uniq | head | tail | cut | tr | wc | tee | less | more | man | which | whereis | stat | file | touch | mkdir | rmdir | rm | cp | mv | ln | chmod | chown | tar | gzip | gunzip | zip | unzip | ssh | scp | rsync | curl | wget | git | go | make | gcc | dnf | yum | rpm | systemctl | journalctl | service | ps | top | free | df | du | ip | ss | ping | sudo | su | env | bash | sh | python | python3 | node | npm | docker | podman | kubectl | jq | yq | helm | terraform | cargo | rustc | brew | apt | snap | pip | pip3 | conda | mvn | gradle | cmake | ninja | vim | nano | tmux | screen | code)
      return 0
      ;;
    esac
    return 1
  }

  __witty_has_nl_signal() {
    local line="${1:-}"
    local lower=""
    lower="${line,,}"
    case "$line" in
    *'?'* | *'？'* | *[一-龥]*)
      return 0
      ;;
    esac
    case "$lower" in
    "how do "* | "how "* | "what's "* | "what "* | "why "* | "explain "* | "tell me "* | "show me "* | "please "* | "help me "* | "can you "* | "is there "* | *怎么* | *如何* | *帮我* | *请* | *分析* | *解释* | *排查* | *总结* | *检查* | *看看* | *为什么* | *是什么* | *能不能*)
      return 0
      ;;
    esac
    return 1
  }

  __witty_command_exists() {
    local cmd="${1:-}"
    if [ -z "$cmd" ]; then
      return 1
    fi
    if [ -n "${__WITTY_CMD_CACHE[$cmd]+x}" ]; then
      [ "${__WITTY_CMD_CACHE[$cmd]}" = "1" ] && return 0 || return 1
    fi
    if type -t -- "$cmd" >/dev/null 2>&1; then
      __WITTY_CMD_CACHE["$cmd"]=1
      return 0
    fi
    __WITTY_CMD_CACHE["$cmd"]=0
    return 1
  }

  __witty_classify() {
    local line="${1:-}"
    local first=""
    local compact="${line// /}"
    compact="${compact//$'\t'/}"
    compact="${compact//$'\r'/}"
    compact="${compact//$'\n'/}"
    if [ -z "$compact" ]; then
      printf 'empty\n'
      return 0
    fi

    case "$line" in
    /ask\ * | /agent | /agent\ * | /model | /model\ * | /session\ list | /session\ continue\ *)
      printf 'control\n'
      return 0
      ;;
    /new | /help | /exit | /quit | /q)
      printf 'control\n'
      return 0
      ;;
    esac

    read -r first _ <<<"$line"

    case "$first" in
    witty)
      printf 'shell\n'
      return 0
      ;;
    /* | ./* | ../* | ~/* | */*)
      printf 'shell\n'
      return 0
      ;;
    esac

    local backtick=$'\140'
    local dollar_paren="\$("
    local dollar_brace="\${"
    # shellcheck disable=SC2221,SC2222
    case "$line" in
    *"|"* | *">"* | *"<"* | *";"* | *"&&"* | *"||"* | *"$backtick"* | *"$dollar_paren"* | *"$dollar_brace"*)
      printf 'shell\n'
      return 0
      ;;
    esac
    case "$line" in
    *\\)
      printf 'shell\n'
      return 0
      ;;
    esac
    case "$first" in
    [A-Za-z_]*=*)
      printf 'shell\n'
      return 0
      ;;
    esac
    if __witty_is_shell_keyword "$first"; then
      printf 'shell\n'
      return 0
    fi

    if __witty_has_nl_signal "$line"; then
      printf 'agent\n'
      return 0
    fi

    if __witty_is_shell_command "$first"; then
      printf 'shell\n'
      return 0
    fi

    if __witty_command_exists "$first"; then
      printf 'shell\n'
      return 0
    fi

    printf 'agent\n'
  }

  __witty_shell_dispatch() {
    local route="${1:-}"
    shift || true
    if [ "${1:-}" = "--" ]; then
      shift || true
    fi
    local raw="$*"
    builtin history -s -- "$raw" 2>/dev/null || true
    case "$route" in
    agent)
      command "$__WITTY_BINARY" ask -- "$raw"
      ;;
    control)
      command "$__WITTY_BINARY" shell-control -- "$raw"
      ;;
    *)
      printf 'witty shell: unknown route %s\n' "$route" >&2
      return 64
      ;;
    esac
  }

  __witty_debug_hook() {
    local cmd="${BASH_COMMAND:-}"
    [ -z "$cmd" ] && return 0
    local enabled="${WITTY_SHELL_ENABLE:-}"
    if [ -z "$enabled" ]; then
      enabled="$__WITTY_DEFAULT_ENABLE"
    fi
    case "$enabled" in
    0 | false | FALSE | False | no | NO | No | off | OFF | Off)
      return 0
      ;;
    esac
    local route=""
    route="$(__witty_classify "$cmd")"
    __witty_debug "classify ${route}: ${cmd}"
    case "$route" in
    empty | shell)
      return 0
      ;;
    agent | control)
      __witty_shell_dispatch "$route" -- "$cmd"
      return 1
      ;;
    esac
    return 0
  }

  __witty_command_not_found_handle() {
    local cmd="$1"
    shift || true
    if __witty_should_enable 2>/dev/null; then
      command "$__WITTY_BINARY" ask -- "$cmd $*"
      return $?
    fi
    printf 'witty: command not found: %s\n' "$cmd" >&2
    return 127
  }

  __witty_install_bindings() {
    if [ "${__WITTY_BINDINGS_INSTALLED:-}" = "1" ]; then
      return 0
    fi
    __witty_should_enable || return 0

    declare -gA __WITTY_CMD_CACHE 2>/dev/null || true

    shopt -s extdebug

    local _wit_hig="__witty_shell_dispatch *"
    if [ -n "${HISTIGNORE:-}" ]; then
      case ":$HISTIGNORE:" in
      *":$_wit_hig:"*) ;;
      *) HISTIGNORE="${_wit_hig}:${HISTIGNORE}" ;;
      esac
    else
      HISTIGNORE="${_wit_hig}"
    fi
    export HISTIGNORE

    __witty_prev_debug_trap=""
    if [ "$(trap -p DEBUG)" ]; then
      __witty_prev_debug_trap=$(trap -p DEBUG)
    fi
    trap '__witty_debug_hook' DEBUG

    if [ "$(type -t command_not_found_handle 2>/dev/null)" = "function" ]; then
      __witty_prev_command_not_found_handle=$(declare -f command_not_found_handle)
    fi
    command_not_found_handle() { __witty_command_not_found_handle "$@"; }

    __WITTY_BINDINGS_INSTALLED=1
    __witty_debug 'bindings installed'
  }

  __witty_uninstall_bindings() {
    if [ "${__WITTY_BINDINGS_INSTALLED:-}" != "1" ]; then
      return 0
    fi
    if [ -n "$__witty_prev_debug_trap" ]; then
      eval "$__witty_prev_debug_trap"
    else
      trap - DEBUG
    fi
    shopt -u extdebug
    if [ -n "${__witty_prev_command_not_found_handle:-}" ]; then
      eval "$__witty_prev_command_not_found_handle"
    else
      unset -f command_not_found_handle 2>/dev/null || true
    fi
    __WITTY_BINDINGS_INSTALLED=0
    __witty_debug 'bindings uninstalled'
  }

  __witty_install_bindings
fi
