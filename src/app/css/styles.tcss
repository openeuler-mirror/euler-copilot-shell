/* Witty Assistant CSS 样式 */

/* 主应用样式 */
Hermes {
    layout: vertical;
}

/* 输出区域样式 - 占据除了输入区域外的所有空间 */
#output-container {
    height: 1fr;
    overflow: auto;
    scrollbar-size: 1 1;
    margin: 1 0;
}

/* LOGO 样式 - 靠左、靠上对齐 */
#witty-logo {
    height: auto;
    width: 100%;
    margin: 1 1;
    padding: 0;
}

/* 文本区域 */
Static {
    height: auto;
    padding: 1 1;
    border: none;
}

/* Markdown 渲染优化：消除多余空行与错位 */
Markdown,
MarkdownBlock,
MarkdownParagraph,
MarkdownHeader,
MarkdownList,
MarkdownListItem,
MarkdownListItemMarker,
MarkdownCodeBlock {
    padding: 0;
    margin: 0;
    border: none;
}

Markdown {
    padding: 0 1;
    margin: 1 0;
}

MarkdownParagraph,
MarkdownList,
MarkdownCodeBlock {
    margin: 1 0;
}

MarkdownHeader,
MarkdownH1,
MarkdownH2,
MarkdownH3,
MarkdownH4,
MarkdownH5,
MarkdownH6 {
    margin-bottom: 1;
}

MarkdownList {
    margin-left: 2;
}

MarkdownBulletList,
MarkdownOrderedList {
    margin: 1 0;
}

MarkdownBulletList Horizontal,
MarkdownOrderedList Horizontal {
    height: auto;
    width: 1fr;
    align: left top;
    content-align: left top;
}

MarkdownBulletList Vertical,
MarkdownOrderedList Vertical {
    height: auto;
    width: 1fr;
    padding: 0;
    margin: 0;
    align: left top;
}

MarkdownBullet {
    width: 3;
    min-width: 3;
    content-align: right top;
    margin: 0 1 0 0;
}

MarkdownBulletList Vertical > MarkdownParagraph,
MarkdownOrderedList Vertical > MarkdownParagraph,
MarkdownBulletList Vertical > MarkdownHeading,
MarkdownOrderedList Vertical > MarkdownHeading {
    margin: 0;
}

MarkdownBulletList Vertical > MarkdownParagraph:first-child,
MarkdownOrderedList Vertical > MarkdownParagraph:first-child,
MarkdownBulletList Vertical > MarkdownHeading:first-child,
MarkdownOrderedList Vertical > MarkdownHeading:first-child {
    margin-top: 0;
}

MarkdownBulletList Vertical > MarkdownParagraph:last-child,
MarkdownOrderedList Vertical > MarkdownParagraph:last-child,
MarkdownBulletList Vertical > MarkdownHeading:last-child,
MarkdownOrderedList Vertical > MarkdownHeading:last-child {
    margin-bottom: 0;
}

MarkdownFence,
MarkdownCodeBlock {
    margin: 1 0;
}

/* 用户输入的命令行样式 */
.command-line {
    color: #688efd;
    padding: 0 1;
}

.llm-output {
    margin-top: 1;
}

/* 底部输入区域样式 */
#input-container {
    height: auto;
    min-height: 3;
    dock: bottom;
    padding: 0 1;
    border-top: solid #688efd;
    width: 100%;
    overflow: auto;
    scrollbar-size: 1 1;
}

/* 输入框样式 */
#command-input {
    width: 100%;
    color: #688efd;
    padding: 0 1;
    border: none;
    height: 1;
    max-height: 1;
}

/* 设置界面样式 */
SettingsScreen {
    align: center middle;
}

#settings-screen {
    align: center middle;
    width: 85%;
    height: 95%;
    max-width: 120;
    max-height: 50;
    color: #ffffff;
}

/* 设置容器样式 */
#settings-container {
    align: center top;
    border: solid #4963b1;
    padding: 1 2;
}

/* 设置标题样式 */
#settings-title {
    text-align: center;
    color: #4963b1;
    padding-bottom: 1;
}

/* 设置选项样式 */
.settings-option {
    padding: 1 0;
    width: 100%;
    height: auto;
    align: left middle;
}

/* 设置标签样式 */
.settings-label {
    width: 20%;
    content-align: right middle;
    padding-right: 1;
    margin-top: 1;
}

/* 设置值样式 (可编辑类型) */
.settings-input {
    width: 80%;
    content-align: left middle;
}

/* 设置值容器（用于包含值和徽章） */
.settings-value-container {
    margin-left: 1;
    background: $surface;
    width: 80%;
    height: 3;
    align: left middle;
}

/* 设置值样式 (只读类型) */
.settings-value {
    margin-left: 1;
    width: auto;
    height: 3;
}

/* 用户类型徽章样式 */
.user-type-badge {
    width: 20%;
    height: 3;
    text-style: bold;
    text-align: right;
    margin-top: 1;
    margin-right: 1;
    padding: 0 1;
    dock: right;
}

/* 管理员徽章颜色 */
.user-type-admin {
    color: $warning;
}

/* 普通用户徽章颜色 */
.user-type-user {
    color: $primary;
}

/* 设置按钮样式 */
.settings-button {
    content-align: left middle;
    color: #4963b1;
    border: solid #4963b1;
    width: 40%;
    margin-left: 1;
}

#save-btn, #cancel-btn {
    width: auto;
    min-width: 16;
    height: 3;
    margin: 0 1;
}

/* 操作按钮容器样式 */
#action-buttons {
    align: center middle;
    dock: bottom;
    height: auto;
    margin-top: 1;
    padding: 1;
    content-align: center bottom;
}

/* 退出对话框屏幕样式 */
ExitDialog {
    align: center middle;
}

#exit-dialog-screen {
    align: center middle;
    width: 50%;
    height: 12;
    border: solid #ff5252;
    color: #ffffff;
    margin: 1 1;
    padding: 1;
}

/* 退出对话框样式 */
#exit-dialog {
    align: center middle;
}

/* 对话框文本样式 */
#dialog-text {
    text-align: center;
    margin-bottom: 1;
    padding: 1;
}

/* 对话框按钮容器 */
#dialog-buttons {
    align: center middle;
    width: 100%;
    height: 3;
    margin-top: 1;
}

/* 智能体选择对话框屏幕样式 */
AgentSelectionDialog {
    align: center middle;
}

#agent-dialog-screen {
    align: center middle;
    width: 60%;
    height: 70%;
    border: solid #4963b1;
    color: #ffffff;
    margin: 1 1;
    padding: 1;
}

/* 智能体选择对话框样式 */
#agent-dialog {
    align: center middle;
    min-height: 17;
}

/* 智能体对话框标题样式 */
#agent-dialog-title {
    text-align: center;
    margin-bottom: 1;
    padding: 1;
    color: #688efd;
    text-style: bold;
}

/* 智能体内容显示区域 */
#agent-content {
    height: 1fr;
    width: 100%;
    background: #1a1a1a;
    color: #ffffff;
    padding: 2;
    border: solid #688efd;
    margin: 1 0;
    overflow: auto;
    scrollbar-size: 1 1;
}

/* 智能体对话框帮助文本样式 */
#agent-dialog-help {
    text-align: center;
    margin-top: 1;
    padding: 1;
    color: #aaaaaa;
    text-style: italic;
}

/* 后端要求对话框屏幕样式 */
BackendRequiredDialog {
    align: center middle;
}

#backend-dialog-screen {
    align: center middle;
    width: 50%;
    height: 15;
    border: solid #ff9800;
    color: #ffffff;
    margin: 1 1;
    padding: 1;
}

/* 后端要求对话框样式 */
#backend-dialog {
    align: center middle;
}

/* 后端对话框标题样式 */
#backend-dialog-title {
    text-align: center;
    margin-bottom: 1;
    padding: 1;
    color: #ff9800;
    text-style: bold;
}

/* 后端对话框文本样式 */
#backend-dialog-text {
    text-align: center;
    margin-bottom: 1;
    padding: 1;
    color: #ffffff;
}

/* 后端对话框帮助文本样式 */
#backend-dialog-help {
    text-align: center;
    margin-top: 1;
    padding: 1;
    color: #aaaaaa;
    text-style: italic;
}

/* MCP 组件样式 */
#mcp-confirm, #mcp-parameter {
    height: auto;
    width: 100%;
    padding: 1;
    border: solid #ff9800;
    background: #1a1a1a;
}

/* MCP 模式下的输入容器 */
#input-container.mcp-mode {
    height: auto;
}

/* 正常模式下的输入容器 */
#input-container.normal-mode {
    height: 3;
    min-height: 3;
    max-height: 3;
}

/* MCP 确认组件样式 */
.confirm-info {
    text-align: left;
    color: #ffffff;
    height: auto;
    padding: 0 1;
    margin-bottom: 1;
}

.confirm-buttons {
    height: 3;
    align: center middle;
    margin-top: 0;
}

/* MCP 组件内部容器样式 - 防止占用全部空间 */
#mcp-confirm > Vertical, #mcp-parameter > Vertical {
    height: auto;
}

.mcp-content {
    height: auto;
    layout: vertical;
}

.help-text {
    color: #888888;
    text-style: italic;
    width: auto;
}

.risk-low {
    color: #4caf50;
}

.risk-medium {
    color: #ff9800;
}

.risk-high {
    color: #f44336;
}

/* MCP 参数组件样式 */
.param-header {
    text-align: center;
    text-style: bold;
    color: #2196f3;
    margin-bottom: 0;
    height: auto;
    padding: 0 1;
}

.param-tool {
    text-align: left;
    color: #4caf50;
    height: auto;
    padding: 0 1;
    margin-bottom: 0;
}

.param-input-compact {
    width: 100%;
    margin-bottom: 0;
}

.param-buttons {
    height: 3;
    align: center middle;
    margin-top: 0;
}

/* MCP 按钮样式 */
#mcp-confirm-yes, #mcp-confirm-no, #mcp-param-submit, #mcp-param-cancel {
    margin: 0 1;
    width: auto;
    min-height: 3;
    height: 3;
}

/* MCP 进度块样式 */
.mcp-progress-block {
    background: rgba(223, 225, 229, 0.08);
    border-left: solid #e0e0e0;
    padding: 0 1;
    margin-top: 1;
}

.mcp-progress-block MarkdownParagraph {
    margin: 0;
}

.mcp-waiting-block {
    background: rgba(255, 152, 0, 0.12);
    border-left: solid #ff9800;
    padding: 1 2;
    margin-top: 1;
}

.mcp-waiting-block MarkdownParagraph {
    margin: 0;
}

/* 初始化 - 模式选择界面 */
.mode-container {
    background: $surface;
    border: solid $primary;
    padding: 2;
}

.mode-title {
    color: #4963b1;
    text-style: bold;
    text-align: center;
    padding: 1;
    margin-bottom: 1;
}

.mode-description {
    color: #888888;
    text-align: center;
    padding: 1;
    margin-bottom: 2;
}

.options-row {
    height: auto;
    width: 100%;
    align: center middle;
    margin: 2 0;
}

.mode-option {
    width: 1fr;
    height: auto;
    min-height: 11;
    max-height: 12;
    background: $surface;
    border: solid #888888;
    padding: 1;
    margin: 0 2;
    text-align: center;
    text-wrap: wrap;
    color: $text;
}

.mode-option:hover {
    border: solid #4963b1;
    background: rgba(73, 99, 177, 0.1);
}

.mode-option:focus {
    border: solid #688efd;
    background: rgba(104, 142, 253, 0.2);
    outline: none;
}

/* 初始化 - 连接现有服务界面 */
.connect-container {
    background: $surface;
    border: solid $primary;
    padding: 2;
}

.connect-title {
    color: #4963b1;
    text-style: bold;
    text-align: center;
    padding: 1;
}

.connect-description {
    color: #888888;
    text-align: center;
    padding: 1;
}

.validation-status {
    color: #888888;
    text-style: italic;
    text-align: center;
    padding: 1;
}

/* 初始化 - 选择部署模式 - 底部按钮 */
.mode-button-row {
    height: 3;
    align: center middle;
    dock: bottom;
}

.mode-button-row > Button {
    margin: 0 1;
    width: auto;
    min-height: 3;
    height: 3;
}

/* 用户配置对话框样式 */
UserConfigDialog {
    align: center middle;
}

#user-dialog-screen {
    align: center middle;
    width: 80%;
    height: 80%;
    max-width: 100;
    max-height: 40;
}

#user-dialog {
    border: solid #4963b1;
    padding-left: 1;
    padding-right: 1;
    padding-bottom: 0;
    width: 100%;
    height: 100%;
}

/* 标签页容器 */
#user-tabs {
    height: 1fr;
    margin: 1 0;
}

/* 标签页面板 */
#general-tab, #llm-tab {
    layout: vertical;
}

/* 大模型设置标签页内容容器 */
.llm-tab-content {
    height: 1fr;
    width: 100%;
}

/* 常规设置表单样式 */
.general-settings-form {
    padding: 2;
    width: 100%;
    height: 1fr;
}

.form-buttons {
    height: 3;
    align: center middle;
    margin-top: 2;
}

.form-buttons > Button {
    margin: 0 1;
    width: auto;
    min-height: 3;
    height: 3;
}

/* 模型列表容器 */
.llm-model-list {
    height: auto;
    max-height: 1fr;
    overflow-y: auto;
    scrollbar-size: 1 1;
    border: solid #688efd;
    padding: 1;
    margin: 1 0;
}

/* 模型项样式 */
.llm-model-item {
    padding: 0 1;
    color: #ffffff;
}

/* 已保存的模型（当前配置中保存的） */
.llm-model-saved {
    color: #888888;
    text-style: italic;
}

/* 已激活的模型（用空格确认，等待保存） */
.llm-model-activated {
    color: #4caf50;
    text-style: bold;
}

/* 光标所在的模型 */
.llm-model-cursor {
    background: rgba(104, 142, 253, 0.3);
}

/* 模型详情容器 */
.llm-model-detail {
    border: solid #888888;
    padding: 1;
    margin: 1 0;
    background: rgba(73, 99, 177, 0.1);
    height: auto;
    max-height: 15;
    overflow-y: auto;
    scrollbar-size: 1 1;
    dock: bottom;
}

/* 详情行 */
.llm-detail-row {
    height: auto;
    padding: 0;
    margin: 0;
}

/* 详情标签 */
.llm-detail-label {
    color: #888888;
    width: auto;
    padding-right: 1;
    margin-top: 1;
    text-align: right;
}

/* 详情值 */
.llm-detail-value {
    color: #ffffff;
    width: 1fr;
}

/* 常规设置按钮区域 */
#general-buttons {
    height: auto;
    min-height: 3;
    align: center middle;
    padding: 0;
    dock: bottom;
}

#general-buttons > Button {
    margin: 0 1;
    width: auto;
    min-height: 3;
    height: 3;
}

/* 大模型设置帮助文本 */
.llm-dialog-help {
    text-align: center;
    color: #888888;
    padding: 0 1;
    height: auto;
    min-height: 1;
    dock: bottom;
}

/* 加载状态 */
.llm-loading, .llm-error, .llm-empty {
    text-align: center;
    color: #888888;
    padding: 2;
}
